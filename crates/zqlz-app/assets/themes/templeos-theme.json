{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "TempleOS Theme",
  "author": "b6k",
  "themes": [
    {
      "name": "TempleOS",
      "appearance": "light",
      "style": {
        "background": "#FFFFFF",
        "foreground": "#000000",
