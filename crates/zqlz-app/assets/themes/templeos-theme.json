        "border.disabled": "#AAAAAA",
        "elevated_surface.background": "#FFFFFF",
        "surface.background": "#FFFFFF",
        "background.appearance": "opaque",
        "element.background": "#AAAAAA",
        "element.hover": "#55FFFF",
        "element.active": "#0000AA",
        "element.selected": "#66A8A8",
        "element.disabled": "#AAAAAA",
        "ghost_element.background": "#FFFFFF",
        "ghost_element.hover": "#55FFFF",
        "ghost_element.active": "#0000AA",
        "ghost_element.selected": "#00AAAA",
